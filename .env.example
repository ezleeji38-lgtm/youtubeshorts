# 채널 이름 (각자 본인 채널로)
CHANNEL_NAME=coolvibeply

# OpenAI Whisper — 영문 STT
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google Gemini — 한국어 번역
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Creatomate — 9:16 자막 영상 렌더링
# https://creatomate.com → API Keys
CREATOMATE_API_KEY=

# 로컬 저장 경로 (생성된 mp4와 SQLite DB가 여기 저장)
STORAGE_LOCAL_DIR=./storage

# CORS — 나중에 프론트엔드 붙일 때 사용
ALLOWED_ORIGINS=http://localhost:3000
