# 채널 이름 (각자 본인 채널로)
CHANNEL_NAME=coolvibeply

# OpenAI Whisper — 영문 STT
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google Gemini — 한국어 번역
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# 자막 폰트 (시스템에 설치된 이름)
# macOS 기본:   Helvetica / AppleSDGothicNeo-Bold
# Windows 권장: Arial / Malgun Gothic
FONT_EN=Helvetica
FONT_KO=AppleSDGothicNeo-Bold

# 로컬 저장 경로 (생성된 mp4와 SQLite DB가 여기 저장)
STORAGE_LOCAL_DIR=./storage

# CORS — 나중에 프론트엔드 붙일 때 사용
ALLOWED_ORIGINS=http://localhost:3000
